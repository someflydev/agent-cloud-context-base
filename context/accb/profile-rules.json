    "container-aca-fastapi": ["container", "secrets", "iac"],
    "container-aca-dotnet": ["container", "secrets", "iac"],
    "container-aca-jobs": ["container", "eventing", "secrets", "iac"],
    "k8s-eks-multi-role-python": ["k8s-api", "k8s-worker", "k8s-job", "k8s-cron", "iac", "secrets"],
    "k8s-eks-multi-role-go": ["k8s-api", "k8s-worker", "k8s-job", "k8s-cron", "iac", "secrets"],
    "k8s-gke-multi-role-python": ["k8s-api", "k8s-worker", "k8s-job", "k8s-cron", "iac", "secrets", "vector-store"],
