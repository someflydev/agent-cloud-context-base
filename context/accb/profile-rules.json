  "default_validation_gates": [
    {
      "id": "changed-boundary-proof",
      "category": "completion",
      "summary": "Do not claim completion until the changed cloud boundary was exercised by a real check.",
      "command_hint": "Run at least one direct proof command for the touched boundary (Lane A emulator or Lane B ephemeral real)."
    },
    {
      "id": "iac-dev-test-disjoint",
      "category": "iac",
      "summary": "Dev and test must never share state backend keys, secret paths, or resource names.",
      "command": "python3 scripts/validate_iac_isolation.py <iac dir>",
      "command_hint": "python3 scripts/validate_iac_isolation.py <iac dir>"
    },
    {
      "id": "secret-not-in-source",
      "category": "secrets",
      "summary": "No secret values appear in source, IaC tfvars, Pulumi config without --secret, container images, or logs.",
      "command_hint": "Grep + the validate_iac_isolation policy."
    },
    {
      "id": "identity-least-privilege-declared",
      "category": "identity",
      "summary": "Every workload-to-resource access has an explicit identity binding scoped to the smallest action set.",
      "command_hint": "IaC review + the identity-least-privilege policy."
    },
    {
      "id": "startup-rehydration",
      "category": "operations",
      "summary": "Refresh repo-local operating context when work changes startup order, constraints, or verification commands.",
      "command_hint": "Refresh `.accb/profile/selection.json` and `.accb/SESSION_BOOT.md` when truth changed."
    }
  ],
  "archetype_validation_gates": {
    "cloud-function-repo": [
      {"id": "function-trigger-contract", "category": "trigger", "summary": "Exercise the function with a real trigger event fixture."},
      {"id": "function-idempotency-proof", "category": "replay", "summary": "Replay the same trigger with the same dedupe key and assert exactly-once effect."}
    ],
    "multi-function-platform": [
      {"id": "function-trigger-contract", "category": "trigger", "summary": "Exercise each function with a real trigger event fixture."},
      {"id": "function-idempotency-proof", "category": "replay", "summary": "Replay each trigger and assert exactly-once effect."},
      {"id": "eventing-dlq-path", "category": "eventing", "summary": "Verify DLQ destination, alarm, and replay path."}
    ],
    "managed-container-service": [
      {"id": "container-image-buildable", "category": "build", "summary": "Container image builds with a clean SBOM and non-root user."},
      {"id": "container-health-and-readiness", "category": "smoke", "summary": "Service responds to health and readiness probes after deploy."}
    ],
    "managed-container-multi-service": [
      {"id": "container-image-buildable", "category": "build", "summary": "All images build clean."},
      {"id": "container-health-and-readiness", "category": "smoke", "summary": "Public + private services respond to probes."},
      {"id": "container-private-network-when-required", "category": "network", "summary": "Private worker is unreachable from the public internet."}
    ],
    "k8s-platform-repo": [
      {"id": "k8s-role-separation-evident", "category": "topology", "summary": "API, worker, job, cron live in distinct workloads."},
      {"id": "k8s-rolling-rollout-and-rollback-paths", "category": "rollout", "summary": "Rolling update and rollback both succeed in test."},
      {"id": "eventing-dlq-path", "category": "eventing", "summary": "Worker DLQ path is exercised."}
    ],
    "k8s-multi-tenant-platform": [
      {"id": "k8s-role-separation-evident", "category": "topology", "summary": "Roles are separated."},
      {"id": "k8s-tenant-isolation-evident", "category": "tenancy", "summary": "ResourceQuota, LimitRange, NetworkPolicy per tenant namespace."}
    ],
    "cloud-event-pipeline": [
      {"id": "function-trigger-contract", "category": "trigger", "summary": "Each pipeline stage exercised with a real trigger."},
      {"id": "eventing-dlq-path", "category": "eventing", "summary": "DLQ + replay path verified."},
      {"id": "function-idempotency-proof", "category": "replay", "summary": "End-to-end replay assertion."}
    ],
    "cloud-data-acquisition": [
      {"id": "storage-real-roundtrip-in-test-stack", "category": "data", "summary": "Source ingestion writes and reads through the real managed storage boundary in test."},
      {"id": "function-idempotency-proof", "category": "replay", "summary": "Replay the same source item and assert exactly-once persistence."}
    ],
    "cloud-rag-pipeline": [
      {"id": "rag-retrieval-sanity", "category": "retrieval", "summary": "One indexing and one retrieval query succeed against a deterministic corpus in test."},
      {"id": "secret-binding-via-identity", "category": "secrets", "summary": "Embedding, model, or search credentials are read via provider identity and secret binding."}
    ],
    "cloud-control-plane": [
      {"id": "identity-least-privilege-declared", "category": "identity", "summary": "Control-plane actions use explicit least-privilege workload identity."},
      {"id": "function-idempotency-proof", "category": "replay", "summary": "Replay one mutating request and assert exactly-once managed-state effect."}
    ],
    "cloud-iac-only-repo": [
      {"id": "iac-plan-clean", "category": "iac", "summary": "terraform plan / pulumi preview clean for both dev and test."}
    ],
    "cloud-multi-provider-experiment": [
      {"id": "comparative-parity-evident", "category": "comparative", "summary": "Each provider implementation passes its own provider-specific gates."}
    ]
  },
  "stack_validation_gates": {
    "aws-lambda-python": [
      {"id": "lambda-handler-contract", "category": "trigger", "summary": "Handler invoked with a real event JSON; status, response shape, and side effects asserted."}
    ],
    "aws-lambda-typescript-node": [
      {"id": "lambda-handler-contract", "category": "trigger", "summary": "Handler invoked with a real event JSON; status, response shape, and side effects asserted."}
    ],
    "gcp-cloudfn-python": [
      {"id": "cloudfn-trigger-contract", "category": "trigger", "summary": "Function invoked with a real CloudEvent or HTTP request; idempotency asserted."}
    ],
    "azure-fn-dotnet-isolated": [
      {"id": "azure-fn-trigger-contract", "category": "trigger", "summary": "Function invoked with the real binding payload; isolated-process startup asserted."}
    ],
    "cloudrun-python-fastapi": [
      {"id": "cloudrun-revision-readiness", "category": "smoke", "summary": "Cloud Run revision passes readiness; one representative route exercised."}
    ],
    "eks-base": [
      {"id": "eks-cluster-reachable", "category": "smoke", "summary": "kubectl get nodes succeeds; sample workload Ready."}
    ],
    "iac-terraform-conventions": [
      {"id": "terraform-plan-clean", "category": "iac", "summary": "terraform plan returns no unintended drift in dev and test."}
    ],
    "iac-pulumi-python": [
      {"id": "pulumi-preview-clean", "category": "iac", "summary": "pulumi preview returns no unintended drift in dev and test."}
    ]
  },
  "capability_validation_gates": {
    "function": [
      {"id": "function-trigger-contract", "category": "trigger", "summary": "At least one representative trigger fixture exercises the handler end to end."}
    ],
    "container": [
      {"id": "container-health-and-readiness", "category": "smoke", "summary": "Health and readiness probes pass after deploy."}
    ],
    "k8s-api": [
      {"id": "k8s-role-separation-evident", "category": "topology", "summary": "API role is its own Deployment."}
    ],
    "k8s-worker": [
      {"id": "k8s-worker-bounded-work-item", "category": "workers", "summary": "Worker claims and processes a bounded test work item end to end."}
    ],
    "k8s-job": [
      {"id": "k8s-job-completion", "category": "jobs", "summary": "Job runs to completion in test with parallelism explicit."}
    ],
    "k8s-cron": [
      {"id": "k8s-cron-execution", "category": "cron", "summary": "CronJob fires on schedule in test; concurrencyPolicy honored."}
    ],
    "k8s-tenancy": [
      {"id": "k8s-tenant-isolation-evident", "category": "tenancy", "summary": "ResourceQuota + NetworkPolicy enforce tenant isolation in test."}
    ],
    "iac": [
      {"id": "iac-plan-clean", "category": "iac", "summary": "terraform plan / pulumi preview clean for dev and test."},
      {"id": "iac-dev-test-disjoint", "category": "iac", "summary": "validate_iac_isolation passes."}
    ],
    "secrets": [
      {"id": "secret-binding-via-identity", "category": "secrets", "summary": "Workload reads secrets via identity binding, not env-var copy/paste."}
    ],
    "identity": [
      {"id": "identity-least-privilege-declared", "category": "identity", "summary": "All identity bindings are scoped to least privilege."}
    ],
    "eventing": [
      {"id": "eventing-dlq-path", "category": "eventing", "summary": "DLQ destination + alarm + replay path verified."}
    ],
    "storage": [
      {"id": "storage-real-roundtrip-in-test-stack", "category": "data", "summary": "Workload writes and reads through the real managed-service boundary in test."}
    ],
    "vector-store": [
      {"id": "rag-retrieval-sanity", "category": "retrieval", "summary": "One indexing + one retrieval query succeed against a deterministic corpus in test."}
    ],
    "search": [
      {"id": "search-index-and-query", "category": "retrieval", "summary": "Index + query succeed in test."}
    ],
    "comparative": [
      {"id": "comparative-parity-evident", "category": "comparative", "summary": "Every provider implementation passes its own gates."}
    ]
  }
}
