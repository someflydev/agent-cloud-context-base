    "cloud-data-acquisition": ["function", "container", "storage", "eventing", "iac"],
    "cloud-rag-pipeline": ["function", "container", "vector-store", "iac", "secrets"],
    "cloud-control-plane": ["function", "container", "iac", "secrets"],
    "cloud-iac-only-repo": ["iac"],
    "cloud-multi-provider-experiment": ["function", "container", "iac", "comparative"]
