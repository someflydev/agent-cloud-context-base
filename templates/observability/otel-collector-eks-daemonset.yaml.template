apiVersion: apps/v1
kind: DaemonSet
metadata: { name: otel-collector }
spec:
  selector: { matchLabels: { app: otel-collector } }
  template:
    metadata: { labels: { app: otel-collector } }
    spec:
      containers:
        - name: collector
          image: otel/opentelemetry-collector-contrib:0.100.0
