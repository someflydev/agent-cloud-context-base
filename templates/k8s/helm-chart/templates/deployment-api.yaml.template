apiVersion: apps/v1
kind: Deployment
metadata: { name: {{repo_slug}}-api }
spec:
  replicas: 2
  selector: { matchLabels: { role: api } }
  template:
    metadata: { labels: { role: api } }
    spec:
      serviceAccountName: api
      containers:
        - name: api
          image: "{{image_registry}}/{{image_repository}}:{{image_tag}}"
          ports: [{ containerPort: 8080 }]
