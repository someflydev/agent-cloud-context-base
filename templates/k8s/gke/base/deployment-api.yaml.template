apiVersion: apps/v1
kind: Deployment
metadata:
  name: api
spec:
  replicas: 2
  selector: { matchLabels: { app: {{repo_slug}}, role: api } }
  template:
    metadata: { labels: { app: {{repo_slug}}, role: api } }
    spec:
      serviceAccountName: api
      containers:
        - name: api
          image: {{image_registry}}/{{image_repository}}:{{image_tag}}
          ports: [{ containerPort: 8080 }]
          env: [{ name: ACCB_ENV, value: dev }]
          readinessProbe: { httpGet: { path: /readyz, port: 8080 } }
          livenessProbe: { httpGet: { path: /healthz, port: 8080 } }
