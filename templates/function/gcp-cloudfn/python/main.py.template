import json
import logging

logger = logging.getLogger(__name__)

def handler(request):
    dedupe_key = request.headers.get("Idempotency-Key") or request.headers.get("X-Cloud-Trace-Context")
    logger.info("function_entry", extra={"service":"{{repo_slug}}","dedupe_key":dedupe_key})
    # persist_effect(dedupe_key, request.get_json(silent=True))
    return (json.dumps({"ok": True}), 200, {"Content-Type": "application/json"})
