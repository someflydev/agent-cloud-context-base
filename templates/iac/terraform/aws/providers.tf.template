terraform {
  required_version = ">= 1.6.0, < 2.0.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

locals {
  common_tags = { repo = "{{repo_slug}}", tool = "accb" }
  common_labels = { repo = "{{repo_slug}}", tool = "accb" }
}

provider "aws" {
  
  default_tags { tags = local.common_tags }
}
